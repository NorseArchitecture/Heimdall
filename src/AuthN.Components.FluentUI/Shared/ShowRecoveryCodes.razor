<StatusMessage Message="@StatusMessage" />
<h3>Recovery codes</h3>
<FluentGrid>
	<FluentGridItem sm="12">
		<FluentMessageBar Margin="@Margin.Bottom2" Intent="MessageBarIntent.Warning" AllowDismiss="false">Put these codes in a safe place.</FluentMessageBar>
		<p>
			If you lose your device and don't have the recovery codes you will lose access to your account.
		</p>
	</FluentGridItem>
	<FluentGridItem sm="12">
		@foreach (var recoveryCode in RecoveryCodes)
		{
			<div>
				<code class="recovery-code">@recoveryCode</code>
			</div>
		}
	</FluentGridItem>
</FluentGrid>

@code {
	/// <summary>The two-factor recovery codes to display, one per line.</summary>
	[Parameter]
	public string[] RecoveryCodes { get; set; } = [];

	/// <summary>An optional status message shown above the recovery codes.</summary>
	[Parameter]
	public string? StatusMessage { get; set; }
}
